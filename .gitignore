# Downloaded model weights (multi-GB, re-fetched via hf download / setup scripts)
models/

# Vendored llama.cpp source + build output (re-cloned/rebuilt via setup scripts)
vendor/

# Python virtual environment
.venv/
__pycache__/
*.pyc

# Insight desktop app's local data (SQLite DB, logs) - personal/local only
insight_desktop/data/*.db
insight_desktop/data/uploads/*
!insight_desktop/data/uploads/.gitkeep
insight_desktop/logs/*.log*
insight_desktop/logs/*.txt
insight_desktop/logs/.insight-terminal-launch.sh
insight_desktop/tools/preview.png

# Insight.app build artifacts (rebuilt on demand via packaging/build_app.sh)
insight_desktop/dist/

# Local candidate CSV working copies (template lives in internal_tools/ogm_foundry/templates/)
my-candidates.csv

# Legacy control center local SQLite (code is in control_center/ and internal_tools/ogm_control_center/)
control_center/data/*.sqlite3

# iOS app local Python venv for XTTS tooling (rebuilt via insight_ios/setup_xtts.sh)
insight_ios/.venv-xtts/

# Foundry local workspace data (bootstrap creates these locally)
internal_tools/ogm_foundry/data/*.db
internal_tools/ogm_foundry/data/*.jsonl
internal_tools/ogm_foundry/data/vault/
internal_tools/ogm_foundry/data/workspace.json
internal_tools/ogm_control_center/data/*.db

# OS cruft
.DS_Store
